# ── REDIS ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── POSTGRESQL ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mexc_signals
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── MINIO ─────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_CHARTS=charts
MINIO_SECURE=false

# ── MEXC API ──────────────────────────────────────────
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_REST_URL=https://api.mexc.com
MEXC_WS_URL=wss://wbs.mexc.com/ws
MEXC_SYMBOLS_PER_WS_CONNECTION=100

# ── TELEGRAM ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── STRATEGY ─────────────────────────────────────────
FILTER_PRICE_CHANGE_PERCENT=8.0
FILTER_RSI_OVERBOUGHT=80
FILTER_RSI_OVERSOLD=20
FILTER_RSI_PERIOD=14
SIGNAL_COOLDOWN_MINUTES=240

# ── BUFFERS ───────────────────────────────────────────
CANDLES_5MIN_BUFFER=200
CANDLES_15MIN_BUFFER=200
CANDLES_1H_BUFFER=50
CHART_HOURS=12

# ── SERVICES ──────────────────────────────────────────
COLLECTOR_HEALTH_PORT=8001
ANALYZER_HEALTH_PORT=8002
CHART_BUILDER_HEALTH_PORT=8003
NOTIFIER_HEALTH_PORT=8004

# ── ENVIRONMENT ────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
